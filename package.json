    "fumadocs-core": "16.7.16",
    "fumadocs-mdx": "14.3.0",
    "fumadocs-ui": "16.7.16",
    "geist": "^1.7.0",
    "lucide-react": "^1.8.0",
    "mermaid": "^11.14.0",
    "next": "16.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
